{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=smartlocker.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "SmartLocker": {
    "AppName": "SmartLocker",
    "Version": "1.0.0",
    "Environment": "Development",
    "BaseUrl": "http://localhost:5000",
    "QrToken": {
      "ExpiryMinutes": 15,
      "MaxFailedAttempts": 5
    },
    "Hardware": {
      "Mode": "Mock",
      "GpioEnabled": false
    }
  },
  "LockerHardware": {
    "Mode": "Mock",
    "UnlockPulseMilliseconds": 1000,
    "Lockers": [
      {
        "LockerId": 1,
        "RelayPin": 17,
        "DoorSensorPin": 27
      },
      {
        "LockerId": 2,
        "RelayPin": 22,
        "DoorSensorPin": 23
      },
      {
        "LockerId": 3,
        "RelayPin": 24,
        "DoorSensorPin": 25
      },
      {
        "LockerId": 4,
        "RelayPin": 26,
        "DoorSensorPin": 16
      },
      {
        "LockerId": 5,
        "RelayPin": 20,
        "DoorSensorPin": 21
      }
    ]
  }
}
