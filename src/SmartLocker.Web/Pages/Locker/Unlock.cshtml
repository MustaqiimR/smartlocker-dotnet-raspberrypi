@page
@model UnlockModel
@{
    Layout = null;
    ViewData["Title"] = "Unlock Locker";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>Unlock Locker - SmartLocker</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
        
        .kiosk-container {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            max-width: 600px;
            width: 100%;
        }
        
        .kiosk-header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .kiosk-header h1 {
            font-size: 36px;
            color: #667eea;
            margin-bottom: 10px;
        }
        
        .kiosk-header p {
            font-size: 16px;
            color: #666;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 10px;
            font-size: 18px;
            font-weight: bold;
            color: #333;
        }
        
        .form-group input {
            width: 100%;
            padding: 15px;
            font-size: 18px;
            border: 2px solid #ddd;
            border-radius: 10px;
            font-family: monospace;
        }
        
        .form-group input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        
        .btn-group {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 30px;
        }
        
        .btn {
            padding: 20px;
            border: none;
            border-radius: 10px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn-submit {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            grid-column: span 2;
        }
        
        .btn-submit:active {
            transform: scale(0.95);
        }
        
        .btn-back {
            background: #6c757d;
            color: white;
        }
        
        .btn-back:active {
            transform: scale(0.95);
        }
        
        .alert {
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 10px;
            font-size: 16px;
        }
        
        .alert-success {
            background-color: #d4edda;
            color: #155724;
            border: 2px solid #c3e6cb;
        }
        
        .alert-danger {
            background-color: #f8d7da;
            color: #721c24;
            border: 2px solid #f5c6cb;
        }
        
        .alert-info {
            background-color: #d1ecf1;
            color: #0c5460;
            border: 2px solid #bee5eb;
        }
        
        .info-text {
            background: #f5f5f5;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            font-size: 14px;
            color: #666;
            line-height: 1.6;
        }
        
        @@media (max-width: 600px) {
            .kiosk-container {
                padding: 20px;
            }
            
            .kiosk-header h1 {
                font-size: 28px;
            }
        }
    </style>
</head>
<body>
    <div class="kiosk-container">
        <div class="kiosk-header">
            <h1>🔓 Unlock Locker</h1>
            <p>Scan your QR code or enter token</p>
        </div>
        
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }
        
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        
        <div class="info-text">
            <strong>Instructions:</strong> Scan the QR code provided in your approval email, or paste the token below.
        </div>
        
        <form method="post">
            <div class="form-group">
                <label for="token">QR Token</label>
                <input type="text" id="token" name="token" placeholder="Scan QR or paste token..." autofocus />
            </div>
            
            <div class="btn-group">
                <a href="/Locker" class="btn btn-back">← Back</a>
                <button type="submit" class="btn btn-submit">Unlock</button>
            </div>
        </form>
    </div>
</body>
</html>
