@page
@model IndexModel
@{
    ViewData["Title"] = "SmartLocker";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>SmartLocker Kiosk</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }
        
        .kiosk-container {
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
            max-width: 600px;
            width: 100%;
            text-align: center;
        }
        
        .kiosk-header {
            margin-bottom: 40px;
        }
        
        .kiosk-header h1 {
            font-size: 48px;
            color: #667eea;
            margin-bottom: 10px;
        }
        
        .kiosk-header p {
            font-size: 18px;
            color: #666;
        }
        
        .kiosk-menu {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .kiosk-button {
            padding: 40px 20px;
            border: none;
            border-radius: 15px;
            font-size: 24px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 15px;
            min-height: 150px;
        }
        
        .kiosk-button:active {
            transform: scale(0.95);
        }
        
        .btn-unlock {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .btn-unlock:hover {
            box-shadow: 0 5px 20px rgba(102, 126, 234, 0.4);
        }
        
        .btn-return {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            color: white;
        }
        
        .btn-return:hover {
            box-shadow: 0 5px 20px rgba(245, 87, 108, 0.4);
        }
        
        .icon {
            font-size: 48px;
        }
        
        .kiosk-info {
            background: #f5f5f5;
            padding: 20px;
            border-radius: 10px;
            font-size: 14px;
            color: #666;
            line-height: 1.6;
        }
        
        @@media (max-width: 600px) {
            .kiosk-container {
                padding: 20px;
            }
            
            .kiosk-header h1 {
                font-size: 36px;
            }
            
            .kiosk-button {
                padding: 30px 15px;
                font-size: 20px;
                min-height: 120px;
            }
            
            .icon {
                font-size: 36px;
            }
        }
    </style>
</head>
<body>
    <div class="kiosk-container">
        <div class="kiosk-header">
            <h1>SmartLocker</h1>
            <p>Item Management Kiosk</p>
        </div>
        
        <div class="kiosk-menu">
            <a href="/Locker/Unlock" class="kiosk-button btn-unlock">
                <div class="icon">🔓</div>
                <div>Unlock Locker</div>
            </a>
            <a href="/Locker/Return" class="kiosk-button btn-return">
                <div class="icon">📥</div>
                <div>Return Item</div>
            </a>
        </div>
        
        <div class="kiosk-info">
            <p>Tap a button to proceed. For QR unlock, tap "Unlock Locker" and scan your QR code.</p>
        </div>
    </div>
</body>
</html>
