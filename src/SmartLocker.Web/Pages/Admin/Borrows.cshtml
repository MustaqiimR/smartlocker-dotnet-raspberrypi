@page
@model BorrowsModel
@{
    ViewData["Title"] = "Manage Borrows";
}

<div class="page-header">
    <h1>Manage Borrows</h1>
    <p>View and manage active borrowing records</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-header">
        <h3>Active Borrows</h3>
        <span class="badge">@Model.ActiveBorrows.Count</span>
    </div>
    <div class="card-body">
        @if (Model.ActiveBorrows.Count == 0)
        {
            <p class="text-muted">No active borrows at this time.</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Borrow ID</th>
                        <th>User</th>
                        <th>Item</th>
                        <th>Locker</th>
                        <th>Start Date</th>
                        <th>Due Date</th>
                        <th>Days Left</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var borrow in Model.ActiveBorrows)
                    {
                        var daysLeft = (borrow.BorrowEndDate - DateTime.UtcNow).Days;
                        var isOverdue = daysLeft < 0;
                        <tr>
                            <td>@borrow.BorrowId</td>
                            <td>@borrow.User?.FullName</td>
                            <td>@borrow.Item?.ItemName</td>
                            <td>@borrow.Locker?.LockerName</td>
                            <td>@borrow.BorrowStartDate.ToString("yyyy-MM-dd")</td>
                            <td>@borrow.BorrowEndDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (isOverdue)
                                {
                                    <span class="badge badge-danger">Overdue by @Math.Abs(daysLeft) days</span>
                                }
                                else
                                {
                                    <span class="badge badge-info">@daysLeft days</span>
                                }
                            </td>
                            <td><span class="badge badge-success">@borrow.BorrowStatus?.BorrowStatusName</span></td>
                            <td>
                                <button class="btn btn-sm btn-warning" onclick="extendLoan(@borrow.BorrowId)">Extend</button>
                                <button class="btn btn-sm btn-danger" onclick="forceReturn(@borrow.BorrowId)">Force Return</button>
                                <button class="btn btn-sm btn-dark" onclick="markLost(@borrow.BorrowId)">Mark Lost</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Extend Loan Modal -->
<div id="extendModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Extend Loan</h2>
            <span class="close" onclick="closeExtendModal()">&times;</span>
        </div>
        <div class="modal-body">
            <form method="post" id="extendForm">
                <input type="hidden" id="extendBorrowId" name="borrowId" />
                <div class="form-group">
                    <label for="extensionDays">Extension (days)</label>
                    <input type="number" id="extensionDays" name="extensionDays" value="7" min="1" max="30" required />
                </div>
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeExtendModal()">Cancel</button>
            <button class="btn btn-warning" onclick="submitExtend()">Extend</button>
        </div>
    </div>
</div>

<!-- Force Return Modal -->
<div id="returnModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Force Return Item</h2>
            <span class="close" onclick="closeReturnModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to force return this item? The item status will be set to Available and the locker will be freed.</p>
            <form method="post" id="returnForm">
                <input type="hidden" id="returnBorrowId" name="borrowId" />
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeReturnModal()">Cancel</button>
            <button class="btn btn-danger" onclick="submitReturn()">Force Return</button>
        </div>
    </div>
</div>

<!-- Mark Lost Modal -->
<div id="lostModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Mark Item as Lost</h2>
            <span class="close" onclick="closeLostModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to mark this item as lost? The borrow status will be set to Lost and the item status will be Lost.</p>
            <form method="post" id="lostForm">
                <input type="hidden" id="lostBorrowId" name="borrowId" />
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeLostModal()">Cancel</button>
            <button class="btn btn-dark" onclick="submitLost()">Mark Lost</button>
        </div>
    </div>
</div>

<style>
    .modal {
        display: none;
        position: fixed;
        z-index: 1;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.4);
    }

    .modal-content {
        background-color: #fefefe;
        margin: 10% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 80%;
        max-width: 500px;
        border-radius: 10px;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .modal-header h2 {
        margin: 0;
    }

    .close {
        color: #aaa;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .close:hover,
    .close:focus {
        color: black;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 20px;
    }

    .badge {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 12px;
        font-weight: bold;
    }

    .badge-success {
        background-color: #28a745;
        color: white;
    }

    .badge-info {
        background-color: #17a2b8;
        color: white;
    }

    .badge-danger {
        background-color: #dc3545;
        color: white;
    }
</style>

<script>
    function extendLoan(borrowId) {
        document.getElementById('extendBorrowId').value = borrowId;
        document.getElementById('extendModal').style.display = 'block';
    }

    function closeExtendModal() {
        document.getElementById('extendModal').style.display = 'none';
    }

    function submitExtend() {
        document.getElementById('extendForm').action = '@Url.Page("Borrows", "Extend")';
        document.getElementById('extendForm').submit();
    }

    function forceReturn(borrowId) {
        document.getElementById('returnBorrowId').value = borrowId;
        document.getElementById('returnModal').style.display = 'block';
    }

    function closeReturnModal() {
        document.getElementById('returnModal').style.display = 'none';
    }

    function submitReturn() {
        document.getElementById('returnForm').action = '@Url.Page("Borrows", "Return")';
        document.getElementById('returnForm').submit();
    }

    function markLost(borrowId) {
        document.getElementById('lostBorrowId').value = borrowId;
        document.getElementById('lostModal').style.display = 'block';
    }

    function closeLostModal() {
        document.getElementById('lostModal').style.display = 'none';
    }

    function submitLost() {
        document.getElementById('lostForm').action = '@Url.Page("Borrows", "MarkLost")';
        document.getElementById('lostForm').submit();
    }

    window.onclick = function (event) {
        var extendModal = document.getElementById('extendModal');
        var returnModal = document.getElementById('returnModal');
        var lostModal = document.getElementById('lostModal');
        if (event.target == extendModal) {
            extendModal.style.display = 'none';
        }
        if (event.target == returnModal) {
            returnModal.style.display = 'none';
        }
        if (event.target == lostModal) {
            lostModal.style.display = 'none';
        }
    }
</script>
