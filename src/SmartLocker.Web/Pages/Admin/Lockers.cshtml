@page
@model LockersModel
@{
    ViewData["Title"] = "Manage Lockers";
}

<div class="page-header">
    <h1>Manage Lockers</h1>
    <p>Create and manage physical lockers</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.EditingLocker != null)
{
    <div class="card">
        <div class="card-header">
            <h3>Edit Locker</h3>
        </div>
        <form method="post">
            <input type="hidden" name="lockerId" value="@Model.EditingLocker.LockerId" />
            <div class="form-row">
                <div class="form-group">
                    <label for="lockerName">Locker Name</label>
                    <input type="text" id="lockerName" name="lockerName" value="@Model.EditingLocker.LockerName" disabled />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="statusId">Status</label>
                    <select id="statusId" name="statusId" required>
                        <option value="">Select a status</option>
                        @if (Model.EditingLocker.LockerStatusId == 1)
                        {
                            <option value="1" selected>Available</option>
                        }
                        else
                        {
                            <option value="1">Available</option>
                        }
                        @if (Model.EditingLocker.LockerStatusId == 2)
                        {
                            <option value="2" selected>Occupied</option>
                        }
                        else
                        {
                            <option value="2">Occupied</option>
                        }
                        @if (Model.EditingLocker.LockerStatusId == 3)
                        {
                            <option value="3" selected>Locked</option>
                        }
                        else
                        {
                            <option value="3">Locked</option>
                        }
                        @if (Model.EditingLocker.LockerStatusId == 4)
                        {
                            <option value="4" selected>Maintenance</option>
                        }
                        else
                        {
                            <option value="4">Maintenance</option>
                        }
                    </select>
                </div>
            </div>
            <div class="btn-group">
                <button type="submit" class="btn btn-primary" name="action" value="edit">Save Changes</button>
                <a href="/Admin/Lockers" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
}
else
{
    <div class="card">
        <div class="card-header">
            <h3>Add New Locker</h3>
        </div>
        <form method="post">
            <div class="form-row">
                <div class="form-group">
                    <label for="lockerName">Locker Name</label>
                    <input type="text" id="lockerName" name="lockerName" placeholder="e.g., Locker-01" required />
                </div>
            </div>
            <button type="submit" class="btn btn-primary" name="action" value="create">Create Locker</button>
        </form>
    </div>
}

<div class="card">
    <div class="card-header">
        <h3>Lockers List</h3>
    </div>
    @if (Model.Lockers.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Locker Name</th>
                    <th>Status</th>
                    <th>Location</th>
                    <th>Created Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var locker in Model.Lockers)
                {
                    <tr>
                        <td>@locker.LockerName</td>
                        <td>
                            <span class="badge badge-primary">
                                @if (locker.LockerStatusId == 1) { <text>Available</text> }
                                else if (locker.LockerStatusId == 2) { <text>Occupied</text> }
                                else if (locker.LockerStatusId == 3) { <text>Locked</text> }
                                else if (locker.LockerStatusId == 4) { <text>Maintenance</text> }
                            </span>
                        </td>
                        <td>@locker.Location</td>
                        <td>@locker.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <div class="table-actions">
                                <a href="/Admin/Lockers?editId=@locker.LockerId" class="btn btn-secondary">Edit</a>
                                <form method="post" style="display:inline;">
                                    <input type="hidden" name="lockerId" value="@locker.LockerId" />
                                    <button type="submit" class="btn btn-danger" name="action" value="delete" onclick="return confirm('Delete this locker?')">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No lockers found.</p>
    }
</div>
