@page
@model OverdueModel
@{
    ViewData["Title"] = "View Overdue";
}

<div class="page-header">
    <h1>Overdue Items</h1>
    <p>Track and manage items that are past their due date</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-header">
        <h3>Overdue Borrows</h3>
        <span class="badge badge-danger">@Model.OverdueBorrows.Count</span>
    </div>
    <div class="card-body">
        @if (Model.OverdueBorrows.Count == 0)
        {
            <p class="text-muted">No overdue items at this time.</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Borrow ID</th>
                        <th>User</th>
                        <th>Item</th>
                        <th>Locker</th>
                        <th>Due Date</th>
                        <th>Days Overdue</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var borrow in Model.OverdueBorrows)
                    {
                        var daysOverdue = (DateTime.UtcNow - borrow.BorrowEndDate).Days;
                        <tr>
                            <td>@borrow.BorrowId</td>
                            <td>@borrow.User?.FullName</td>
                            <td>@borrow.Item?.ItemName</td>
                            <td>@borrow.Locker?.LockerName</td>
                            <td>@borrow.BorrowEndDate.ToString("yyyy-MM-dd")</td>
                            <td><span class="badge badge-danger">@daysOverdue days</span></td>
                            <td><span class="badge badge-danger">@borrow.BorrowStatus?.BorrowStatusName</span></td>
                            <td>
                                <button class="btn btn-sm btn-info" onclick="sendReminder(@borrow.BorrowId)">Send Reminder</button>
                                <button class="btn btn-sm btn-danger" onclick="forceReturn(@borrow.BorrowId)">Force Return</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Reminder Modal -->
<div id="reminderModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Send Reminder</h2>
            <span class="close" onclick="closeReminderModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p>A reminder notification will be sent to the borrower about the overdue item.</p>
            <form method="post" id="reminderForm">
                <input type="hidden" id="reminderBorrowId" name="borrowId" />
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeReminderModal()">Cancel</button>
            <button class="btn btn-info" onclick="submitReminder()">Send Reminder</button>
        </div>
    </div>
</div>

<!-- Force Return Modal -->
<div id="returnModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Force Return Item</h2>
            <span class="close" onclick="closeReturnModal()">&times;</span>
        </div>
        <div class="modal-body">
            <p>Are you sure you want to force return this overdue item? The item status will be set to Available.</p>
            <form method="post" id="returnForm">
                <input type="hidden" id="returnBorrowId" name="borrowId" />
            </form>
        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeReturnModal()">Cancel</button>
            <button class="btn btn-danger" onclick="submitReturn()">Force Return</button>
        </div>
    </div>
</div>

<style>
    .modal {
        display: none;
        position: fixed;
        z-index: 1;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.4);
    }

    .modal-content {
        background-color: #fefefe;
        margin: 10% auto;
        padding: 20px;
        border: 1px solid #888;
        width: 80%;
        max-width: 500px;
        border-radius: 10px;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .modal-header h2 {
        margin: 0;
    }

    .close {
        color: #aaa;
        font-size: 28px;
        font-weight: bold;
        cursor: pointer;
    }

    .close:hover,
    .close:focus {
        color: black;
    }

    .modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 20px;
    }

    .badge {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 5px;
        font-size: 12px;
        font-weight: bold;
    }

    .badge-danger {
        background-color: #dc3545;
        color: white;
    }
</style>

<script>
    function sendReminder(borrowId) {
        document.getElementById('reminderBorrowId').value = borrowId;
        document.getElementById('reminderModal').style.display = 'block';
    }

    function closeReminderModal() {
        document.getElementById('reminderModal').style.display = 'none';
    }

    function submitReminder() {
        document.getElementById('reminderForm').action = '@Url.Page("Overdue", "SendReminder")';
        document.getElementById('reminderForm').submit();
    }

    function forceReturn(borrowId) {
        document.getElementById('returnBorrowId').value = borrowId;
        document.getElementById('returnModal').style.display = 'block';
    }

    function closeReturnModal() {
        document.getElementById('returnModal').style.display = 'none';
    }

    function submitReturn() {
        document.getElementById('returnForm').action = '@Url.Page("Overdue", "ForceReturn")';
        document.getElementById('returnForm').submit();
    }

    window.onclick = function (event) {
        var reminderModal = document.getElementById('reminderModal');
        var returnModal = document.getElementById('returnModal');
        if (event.target == reminderModal) {
            reminderModal.style.display = 'none';
        }
        if (event.target == returnModal) {
            returnModal.style.display = 'none';
        }
    }
</script>
