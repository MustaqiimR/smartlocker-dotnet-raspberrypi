@page
@model UsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<div class="page-header">
    <h1>Manage Users</h1>
    <p>Create, edit, and manage user accounts</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.EditingUser != null)
{
    <div class="card">
        <div class="card-header">
            <h3>Edit User</h3>
        </div>
        <form method="post">
            <input type="hidden" name="userId" value="@Model.EditingUser.UserId" />
            <div class="form-row">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" value="@Model.EditingUser.Username" disabled />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="fullName">Full Name</label>
                    <input type="text" id="fullName" name="fullName" value="@Model.EditingUser.FullName" required />
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" value="@Model.EditingUser.Email" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="roleId">Role</label>
                    <select id="roleId" name="roleId" required>
                        <option value="">Select a role</option>
                        @foreach (var role in Model.Roles)
                        {
                            if (role.RoleId == Model.EditingUser.RoleId)
                            {
                                <option value="@role.RoleId" selected>@role.RoleName</option>
                            }
                            else
                            {
                                <option value="@role.RoleId">@role.RoleName</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="password">Change Password (leave blank to keep current)</label>
                    <input type="password" id="password" name="password" placeholder="New password (min 6 chars)" />
                </div>
            </div>
            <div class="btn-group">
                <button type="submit" class="btn btn-primary" name="action" value="edit">Save Changes</button>
                <button type="submit" class="btn btn-warning" name="action" value="changePassword" onclick="return confirm('Change password for this user?')">Change Password</button>
                <a href="/Admin/Users" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
}
else
{
    <div class="card">
        <div class="card-header">
            <h3>Add New User</h3>
        </div>
        <form method="post">
            <div class="form-row">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" required />
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="fullName">Full Name</label>
                    <input type="text" id="fullName" name="fullName" required />
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="roleId">Role</label>
                    <select id="roleId" name="roleId" required>
                        <option value="">Select a role</option>
                        @foreach (var role in Model.Roles)
                        {
                            <option value="@role.RoleId">@role.RoleName</option>
                        }
                    </select>
                </div>
            </div>
            <button type="submit" class="btn btn-primary" name="action" value="create">Create User</button>
        </form>
    </div>
}

<div class="card">
    <div class="card-header">
        <h3>Users List</h3>
    </div>
    @if (Model.Users.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Last Login</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td><span class="badge badge-primary">@user.Role.RoleName</span></td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge badge-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">Inactive</span>
                            }
                        </td>
                        <td>@(user.LastLogin?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                        <td>
                            <div class="table-actions">
                                <a href="/Admin/Users?editId=@user.UserId" class="btn btn-secondary">Edit</a>
                                @if (user.IsActive)
                                {
                                    <form method="post" style="display:inline;">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" class="btn btn-danger" name="action" value="disable" onclick="return confirm('Disable this user?')">Disable</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" style="display:inline;">
                                        <input type="hidden" name="userId" value="@user.UserId" />
                                        <button type="submit" class="btn btn-success" name="action" value="enable" onclick="return confirm('Enable this user?')">Enable</button>
                                    </form>
                                }
                                <form method="post" style="display:inline;">
                                    <input type="hidden" name="userId" value="@user.UserId" />
                                    <button type="submit" class="btn btn-danger" name="action" value="delete" onclick="return confirm('Delete this user? This action cannot be undone.')">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No users found.</p>
    }
</div>
