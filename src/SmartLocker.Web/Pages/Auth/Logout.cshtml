@page
@model LogoutModel
@{
    ViewData["Title"] = "Logout";
}

<div class="page-container">
    <div class="logout-container">
        <h1>Logging Out...</h1>
        <p>You have been successfully logged out.</p>
        <p>Redirecting to login page...</p>
    </div>
</div>

<script>
    // Auto-redirect to login after 2 seconds
    setTimeout(function() {
        window.location.href = '/Auth/Login';
    }, 2000);
</script>

<style>
    .logout-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        text-align: center;
    }
    
    .logout-container h1 {
        font-size: 28px;
        margin-bottom: 20px;
        color: #28a745;
    }
    
    .logout-container p {
        font-size: 16px;
        margin: 10px 0;
        color: #666;
    }
</style>
