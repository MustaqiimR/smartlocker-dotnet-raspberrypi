@page
@model ReturnItemModel
@{
    ViewData["Title"] = "Return Item";
}

<div class="page-header">
    <h1>Return Item</h1>
    <p>Return a borrowed item to the locker system</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-header">
        <h3>Return Item</h3>
    </div>
    <form method="post">
        <div class="form-group">
            <label for="borrowId">Select Borrow Record</label>
            <select id="borrowId" name="borrowId" required>
                <option value="">-- Select an item to return --</option>
                @foreach (var borrow in Model.ActiveBorrows)
                {
                    <option value="@borrow.BorrowId">
                        @borrow.Item?.ItemName - Borrowed: @borrow.BorrowStartDate.ToString("yyyy-MM-dd") - Due: @borrow.BorrowEndDate.ToString("yyyy-MM-dd")
                    </option>
                }
            </select>
        </div>
        
        <div class="form-group">
            <label for="notes">Return Notes (Optional)</label>
            <textarea id="notes" name="notes" rows="4" placeholder="Any notes about the item condition..."></textarea>
        </div>
        
        <div class="btn-group">
            <button type="submit" class="btn btn-primary">Return Item</button>
            <a href="/Staff/Dashboard" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<style>
    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #333;
        font-weight: 500;
    }

    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 5px;
        font-size: 14px;
        font-family: inherit;
    }

    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
</style>
