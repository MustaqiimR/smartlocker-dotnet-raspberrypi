@page
@model SearchItemsModel
@{
    ViewData["Title"] = "Search Items";
}

<div class="page-header">
    <h1>Search Items</h1>
    <p>Find items available for borrowing</p>
</div>

<div class="card">
    <div class="card-header">
        <h3>Search & Filter</h3>
    </div>
    <form method="get">
        <div class="form-row">
            <div class="form-group">
                <label for="searchTerm">Item Name / Serial Number</label>
                <input type="text" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Search..." />
            </div>
            <div class="form-group">
                <label for="categoryId">Category</label>
                <select id="categoryId" name="categoryId">
                    <option value="">All Categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        <option value="@category.CategoryId" selected="@(Model.SelectedCategoryId == category.CategoryId ? "selected" : null)">@category.CategoryName</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label for="statusId">Status</label>
                <select id="statusId" name="statusId">
                    <option value="">All Statuses</option>
                    @foreach (var status in Model.ItemStatuses)
                    {
                        <option value="@status.ItemStatusId" selected="@(Model.SelectedStatusId == status.ItemStatusId ? "selected" : null)">@status.ItemStatusName</option>
                    }
                </select>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Search</button>
        <a href="/Staff/Items/Search" class="btn btn-secondary">Clear</a>
    </form>
</div>

<div class="card">
    <div class="card-header">
        <h3>Results (@Model.Items.Count)</h3>
    </div>
    @if (Model.Items.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Locker</th>
                    <th>Serial Number</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ItemName</td>
                        <td>@item.Category?.CategoryName</td>
                        <td>
                            @if (item.ItemStatus?.ItemStatusName == "Available")
                            {
                                <span class="badge badge-success">@item.ItemStatus.ItemStatusName</span>
                            }
                            else
                            {
                                <span class="badge badge-warning">@item.ItemStatus?.ItemStatusName</span>
                            }
                        </td>
                        <td>@(item.Locker?.LockerName ?? "N/A") - @(item.Locker?.Location ?? "")</td>
                        <td>@item.SerialNumber</td>
                        <td>
                            <div class="table-actions">
                                @if (item.ItemStatus?.ItemStatusName == "Available")
                                {
                                    <a href="/Staff/Items/Request/@item.ItemId" class="btn btn-primary">Request</a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary" disabled>Not Available</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No items found. Try adjusting your search criteria.</p>
    }
</div>
