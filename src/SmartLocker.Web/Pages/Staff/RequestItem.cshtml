@page "{id?}"
@model RequestItemModel
@{
    ViewData["Title"] = "Request Item";
}

<div class="page-header">
    <h1>Request Item</h1>
    <p>Submit a request to borrow an item</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Item != null)
{
    <div class="card">
        <div class="card-header">
            <h3>Item Details</h3>
        </div>
        <div style="padding: 20px;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px;">
                <div>
                    <strong>Item Name:</strong>
                    <p>@Model.Item.ItemName</p>
                </div>
                <div>
                    <strong>Category:</strong>
                    <p>@Model.Item.Category?.CategoryName</p>
                </div>
                <div>
                    <strong>Status:</strong>
                    <p><span class="badge badge-info">@Model.Item.ItemStatus?.ItemStatusName</span></p>
                </div>
                <div>
                    <strong>Locker:</strong>
                    <p>@(Model.Item.Locker?.LockerName ?? "N/A")</p>
                </div>
                <div>
                    <strong>Serial Number:</strong>
                    <p>@Model.Item.SerialNumber</p>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Item.Description))
            {
                <div style="margin-top: 20px;">
                    <strong>Description:</strong>
                    <p>@Model.Item.Description</p>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>Submit Request</h3>
        </div>
        <form method="post">
            <input type="hidden" name="itemId" value="@Model.Item.ItemId" />
            <div class="form-group">
                <label for="justification">Justification (Why do you need this item?)</label>
                <textarea id="justification" name="justification" rows="5" required></textarea>
            </div>
            <div class="btn-group">
                <button type="submit" class="btn btn-primary">Submit Request</button>
                <a href="/Staff/SearchItems" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
}
else if (Model.Items.Count > 0)
{
    <div class="card">
        <div class="card-header">
            <h3>Available Items</h3>
        </div>
        <div style="padding: 20px;">
            <form method="get" style="margin-bottom: 20px;">
                <div class="form-group">
                    <input type="text" name="search" placeholder="Search items..." value="@Model.SearchTerm" />
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
            </form>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Item Name</th>
                        <th>Category</th>
                        <th>Serial Number</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ItemName</td>
                            <td>@item.Category?.CategoryName</td>
                            <td>@item.SerialNumber</td>
                            <td>
                                <a href="/Staff/RequestItem?id=@item.ItemId" class="btn btn-sm btn-primary">Request</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-danger">No items found.</div>
}
