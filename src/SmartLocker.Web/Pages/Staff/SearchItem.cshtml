@page
@model SearchItemsModel
@{
    ViewData["Title"] = "Search Items";
}

<div class="page-header">
    <h1>Search Items</h1>
    <p>Find items in the inventory</p>
</div>

<div class="card">
    <div class="card-header">
        <h3>Search and Filter</h3>
    </div>
    <form method="get" class="search-form">
        <div class="form-row">
            <div class="form-group">
                <label for="searchTerm">Search by Name or Serial Number</label>
                <input type="text" id="searchTerm" name="searchTerm" value="@Model.SearchTerm" placeholder="Enter item name or serial number" />
            </div>
            <div class="form-group">
                <label for="categoryId">Category</label>
                <select id="categoryId" name="categoryId">
                    <option value="0">All Categories</option>
                    @foreach (var category in Model.Categories)
                    {
                        if (category.CategoryId == Model.SelectedCategoryId)
                        {
                            <option value="@category.CategoryId" selected>@category.CategoryName</option>
                        }
                        else
                        {
                            <option value="@category.CategoryId">@category.CategoryName</option>
                        }
                    }
                </select>
            </div>
            <div class="form-group">
                <label for="statusId">Status</label>
                <select id="statusId" name="statusId">
                    <option value="0">All Statuses</option>
                    @foreach (var status in Model.ItemStatuses)
                    {
                        if (status.ItemStatusId == Model.SelectedStatusId)
                        {
                            <option value="@status.ItemStatusId" selected>@status.ItemStatusName</option>
                        }
                        else
                        {
                            <option value="@status.ItemStatusId">@status.ItemStatusName</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="btn-group">
            <button type="submit" class="btn btn-primary">Search</button>
            <a href="/Staff/SearchItem" class="btn btn-secondary">Clear</a>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-header">
        <h3>Results</h3>
    </div>
    @if (Model.Items.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Serial Number</th>
                    <th>Location</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.ItemName</td>
                        <td>@item.Category?.CategoryName</td>
                        <td><span class="badge badge-info">@item.ItemStatus?.ItemStatusName</span></td>
                        <td>@item.SerialNumber</td>
                        <td>@(item.Locker?.Location ?? "N/A")</td>
                        <td>
                            <a href="/Staff/RequestItem?id=@item.ItemId" class="btn btn-primary">Request</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No items found. Try adjusting your search criteria.</p>
    }
</div>
